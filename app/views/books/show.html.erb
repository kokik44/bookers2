<div class="container">
  <div class="row">
    <div class="col-xs-3">
      <% if flash[:notice] %>
      <div class="flash">
        <%= flash[:notice] %>
      </div>
      <% end %>
      <h1>User info</h1>
            <%= render 'users/list', users:@user %>
    </div>
    <div class="col-xs-9">
      <h2>Book detail</h2>
       <table class="table table-striped">
         <thead>
           <tr>
             <td></td>
             <td></td>
             <td></td>
           </tr>
         </thead>
         <tbody>
           <tr>
             <td class="col-xs-4">
               <%= attachment_image_tag @user, :profile_image, :fill, 60, 60, class: "img-circle pull-left profile-thumb", fallback: "no_image.jpg" %>
               <%= link_to user_path(@user.id) do %>
                       <%= @user.name %>
                <% end %>
             </td>
             <td class="col-xs-4">
                <%= @book.title %>
             </td>
             <td class="col-xs-4">
               <%= @book.body %>
             </td>
             <% if @book.user == current_user %>
             <td><%= link_to "Edit", edit_book_path(@book.id) %></td>
             <td><%= link_to 'Destroy', book_path(@book), method: :delete %></td>
              <% else %>
            <% end %>
           </tr>
         </tbody>
      </table>
    </div>
  </div>
</div>


