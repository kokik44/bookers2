<div class="container">
    <div class="row">
        <div class="col-xs-3">
            <h1>User info</h1>
            <%= render 'users/list', users:@user %>
        </div>
        <div class="col-xs-9">
             <h2>Users</h2>
               <table class="table table-striped">
               <thead>
                   <tr>
                     <th>title</th>
                     <th>opinion</th>
                     <th></th>
                   </tr>
               </thead>
                <tbody> 
                    <% @books.each do |book| %>
                    <tr>
                    <td class="col-xs-4">
                         <%= link_to user_path(book.user_id) do %>
                            <%= attachment_image_tag (book.user), :profile_image, :fill, 60, 60, class: "img-circle pull-left profile-thumb", fallback: "no_image.jpg" %>
                        <% end %>
                    </td>
                    <td class="col-xs-4">
                        <%= link_to book_path(book.id) do %>
                            <%= book.title %>
                        <% end %>
                    </td>
                    <td class="col-xs-4">
                         <%= book.body %>
                    </td>
                    </tr>
                    <% end %>
                </tbody>
               </table>
        </div>
    </div>
</div>
   
   
