<div class="container">
<div class="row">
<div class="col-xs-3">
<% if @book.errors.any? %>
  <div class="alert alert-warning">
    <ul>
      <%= @book.errors.count %>error
      <% @book.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
<% if flash[:notice] %>
      <div class="flash">
        <%= flash[:notice] %>
      </div>
<% end %>

<h1>User info</h1>
<div class="user-img">
  <%= attachment_image_tag @user, :profile_image, :fill, 60, 60, class: "img-circle pull-left profile-thumb", fallback: "no_image.jpg" %>
</div>

<table class="table">
  <tbody>
    <tr>
      <th>name</th>
      <th><%= @user.name %></th>
    </tr>
    <tr>
      <th>introduction</th>
      <th><%= @user.introduction %></th>
    </tr>
  </tbody>
</table>

<div class="row row-edit">
  <% if @user == current_user %>
   <%= link_to "", edit_user_path(@user), {class: "glyphicon glyphicon-wrench"} %>
   <% else %>
<% end %>
</div>


<h1>New book</h1>
<%= form_for(@book, url: books_path) do |f| %>
  <p>Title</p>
  <%= f.text_field :title %>
  <p>Opinion</p>
  <%= f.text_area :body %>
  <%= f.submit 'Create Book', {class: "btn-create"} %>
<% end %>
</div>

<div class="col-xs-9">
    <h1>Books</h1>
  <table class="table table-striped">
       <thead>
           <tr>
           <th>title</th>
           <th>opinion</th>
           <th></th>
       </tr>
       </thead>
       <tbody>
         <% @books.each do |book| %>
         <tr>
            <td class="col-xs-4">
                <%= link_to book_path(book) do %>
               <%= book.title %>
                <% end %>
            </td>
            <td class="col-xs-8">
               <%= book.body %>
            </td>
         </tr>
         <% end %>
       </tbody>
  </table>
</div>
</div>

<div class="copyright">CopyRight Infratop.inc</div>
</div>
