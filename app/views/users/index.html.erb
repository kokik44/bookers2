<div class="container">
<div class="row">
<div class="col-xs-3">
<h1>User info</h1>
<%= render 'users/list', users:@user %>
</div>

<div class="col-xs-9">
    <h2>Users</h2>
   <table class="table table-striped">
       <thead>
           <tr>
             <th>image</th>
             <th>name</th>
             <th></th>
           </tr>
       </thead>
       <tbody>
        <% @users.each do |user| %>
           <tr>
               <td class="col-xs-4"><%= user.name %></td>
               <td class="col-xs-4"><%= attachment_image_tag user, :profile_image, :fill, 60, 60, class: "img-circle pull-left profile-thumb", fallback: "no_image.jpg" %></td>
               <td class="col-xs-4" ><%= link_to 'Show', user_path(user.id) %></td>
           </tr>
        <% end %>
       </tbody>
   </table>
</div>
</div>
</div>