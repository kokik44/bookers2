<div class="user-img">
  <%= attachment_image_tag @user, :profile_image, :fill, 100, 100, class: "img-circle pull-left profile-thumb", fallback: "no_image.jpg" %>
</div>

<table class="table">
  <tbody>
    <tr>
      <th>name</th>
      <th><%= @user.name %></th>
    </tr>
    <tr>
      <th>introduction</th>
      <th><%= @user.introduction %></th>
    </tr>
  </tbody>
</table>
<div class="row row-edit">
  <% if @user == current_user %>
   <%= link_to "", edit_user_path(@user), {class: "glyphicon glyphicon-wrench"} %>
   <% else %>
<% end %>
</div>




<h1>New book</h1>
<%= form_with model: @book, url: books_path, local: true do |f| %>
  <p>Title</p>
  <%= f.text_field :title %>
  <p>Opinion</p>
  <%= f.text_area :body %>
  <%= f.submit 'Create Book', {class: "btn-create"}  %>
<% end %>